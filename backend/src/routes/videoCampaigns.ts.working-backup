// GET /api/video-campaigns/templates - List all templates
// NOTE: Made public temporarily for debugging - TODO: add authenticate back after fixing token issue
router.get('/templates', async (req, res, next) => {
  try {
    logger.info('📹 [TEMPLATES] Starting templates request');
    const { category, search, system } = req.query;

    // If user is authenticated, show their templates + system templates
    // If not authenticated, show only system templates
    const userId = req.user?.id;
    logger.info(`📹 [TEMPLATES] User ID: ${userId || 'none (unauthenticated)'}`);

    const where: any = userId ? {
      OR: [
        { isSystem: true },
        { userId: userId },
      ],
    } : {
      isSystem: true
    };

    if (category && category !== 'all') {
      where.category = category;
    }

    if (search) {
      where.name = {
        contains: String(search),
        mode: 'insensitive',
      };
    }

    if (system === 'true') {
      where.isSystem = true;
      delete where.OR;
    } else if (system === 'false' && userId) {
      where.isSystem = false;
      where.userId = userId;
      delete where.OR;
    }

    logger.info(`📹 [TEMPLATES] Query where clause: ${JSON.stringify(where)}`);

    const templates = await prisma.videoTemplate.findMany({
      where,
      orderBy: [
        { isFavorite: 'desc' },
        { usageCount: 'desc' },
        { createdAt: 'desc' },
      ],
    });

    logger.info(`📹 [TEMPLATES] Found ${templates.length} templates, sending response`);

    const response = { templates };
    logger.info(`📹 [TEMPLATES] Response JSON size: ${JSON.stringify(response).length} chars`);

    res.json(response);
    logger.info('📹 [TEMPLATES] Response sent successfully');
    return;
  } catch (error) {
    logger.error('❌ [TEMPLATES] Templates endpoint error:', error);
    logger.error('❌ [TEMPLATES] Error details:', JSON.stringify(error, Object.getOwnPropertyNames(error)));
    return next(error);
  }
});

