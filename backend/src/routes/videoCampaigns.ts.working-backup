/**
 * Poll video generation status and update database
 */
async function pollVideoStatus(jobId: string, externalJobId: string, campaignId: string) {
  const videoServiceUrl = process.env.VIDEO_GENERATOR_SERVICE_URL || 'http://localhost:5002';
  const axios = require('axios');
  const maxAttempts = 120; // Poll for up to 20 minutes (120 * 10 seconds)
  let attempts = 0;

  const poll = async () => {
    try {
      logger.info(`[POLL] Checking status for job ${externalJobId}, campaign ${campaignId}`);
      const response = await axios.get(`${videoServiceUrl}/api/video/status/${externalJobId}`);
      const status = response.data;

      logger.info(`[POLL] Received status:`, {
        status: status.status,
        progress: status.progress,
        videoUrl: status.videoUrl,
        hasVideoUrl: !!status.videoUrl,
      });

      // Update job in database
      await prisma.videoGenerationJob.update({
        where: { id: jobId },
        data: {
          status: status.status,
          progress: status.progress || 0,
          currentStep: status.currentStep || 'Processing...',
          errorMessage: status.error,
        },
      });

      // If completed, update campaign
      if (status.status === 'completed' && status.videoUrl) {
        logger.info(`[POLL] Updating campaign ${campaignId} to READY with URL: ${status.videoUrl}`);
        const updatedCampaign = await prisma.videoCampaign.update({
          where: { id: campaignId },
          data: {
            status: 'READY',
            videoUrl: status.videoUrl,
            generatedAt: new Date(),
          },
          include: {
            companies: {
              include: {
                company: {
                  include: {
                    contacts: { take: 1 },
                  },
                },
              },
            },
          },
        });
        logger.info(`✅ Video generation completed for campaign ${campaignId}: ${status.videoUrl}`);

        // AUTO-CREATE EMAIL CAMPAIGN WITH VIDEO
        await autoCreateEmailCampaign(updatedCampaign, status.videoUrl);

        return; // Stop polling
      }

      // If failed, update campaign
      if (status.status === 'failed') {
        await prisma.videoCampaign.update({
          where: { id: campaignId },
          data: {
            status: 'FAILED',
            generationError: status.error || 'Video generation failed',
          },
        });
        logger.error(`Video generation failed for campaign ${campaignId}: ${status.error}`);
        return; // Stop polling
      }

      // Continue polling if still processing
      if (status.status === 'processing' || status.status === 'pending') {
        attempts++;
        if (attempts < maxAttempts) {
          setTimeout(poll, 10000); // Poll every 10 seconds
        } else {
          // Timeout
          await prisma.videoCampaign.update({
            where: { id: campaignId },
            data: {
              status: 'FAILED',
              generationError: 'Video generation timed out',
            },
          });
          logger.error(`Video generation timed out for campaign ${campaignId}`);
        }
      }
    } catch (error: any) {
      logger.error('Poll video status error:', error);
      attempts++;
      if (attempts < maxAttempts) {
        setTimeout(poll, 10000); // Retry
      } else {
        // Mark as failed after max retries
        await prisma.videoCampaign.update({
          where: { id: campaignId },
          data: {
            status: 'FAILED',
            generationError: 'Failed to check video generation status',
          },
        });
      }
    }
  };

  // Start polling after a short delay
  setTimeout(poll, 5000);
}

// POST /api/video-campaigns/:id/generate - Start video generation
router.post('/:id/generate', async (req, res, next) => {
  try {
    const { id } = req.params;

    const campaign = await prisma.videoCampaign.findFirst({
      where: {
        id,
        userId: req.user!.id,
      },
      include: {
        template: true,
      },
    });

    if (!campaign) {
      return res.status(404).json({ error: 'Campaign not found' });
    }

    // Update campaign status
    await prisma.videoCampaign.update({
      where: { id },
      data: { status: 'GENERATING' },
    });

    // Create generation job
    const job = await prisma.videoGenerationJob.create({
      data: {
        campaignId: id,
        status: 'pending',
        currentStep: 'Initializing',
      },
    });

    // Call video generation service
    const videoServiceUrl = process.env.VIDEO_GENERATOR_SERVICE_URL || 'http://localhost:5002';
    const axios = require('axios');

    try {
      const videoGenResponse = await axios.post(`${videoServiceUrl}/api/video/generate`, {
        campaignId: campaign.id,
        narrationScript: campaign.narrationScript,
        templateUrl: campaign.template?.videoUrl || campaign.customVideoUrl,
        voiceId: campaign.voiceId,
        customVoiceUrl: campaign.customVoiceUrl,
        clientLogoUrl: campaign.clientLogoUrl,
        userLogoUrl: campaign.userLogoUrl,
        bgmUrl: campaign.bgmUrl,
        textOverlays: campaign.textOverlays as any,
      }, {
        timeout: 10000, // 10 second timeout for job creation
      });

      logger.info(`Video generation job created: ${videoGenResponse.data.jobId}`);

      // Update job with video service job ID
      await prisma.videoGenerationJob.update({
        where: { id: job.id },
        data: {
          queueId: videoGenResponse.data.jobId,
          status: 'processing',
          currentStep: 'Video generation queued',
          startedAt: new Date(),
        },
      });

      // Start polling for status updates (background task)
      pollVideoStatus(job.id, videoGenResponse.data.jobId, campaign.id).catch((err) => {
        logger.error('Poll video status error:', err);
      });

      return res.json({
        message: 'Video generation started',
        jobId: job.id,
        campaign,
      });
    } catch (videoError: any) {
      logger.error('Video service error:', videoError);

      // Update job and campaign with error
      await prisma.videoGenerationJob.update({
        where: { id: job.id },
        data: {
          status: 'failed',
          errorMessage: videoError.message || 'Video service unavailable',
        },
      });

      await prisma.videoCampaign.update({
        where: { id: campaign.id },
        data: {
          status: 'FAILED',
          generationError: 'Video generation service unavailable. Please try again later.',
        },
      });

      return res.status(503).json({
        error: 'Video generation service unavailable',
        details: videoError.message,
      });
    }
  } catch (error) {
    return next(error);
  }
});

