        details: videoError.message,
        campaign: {
          id: campaign.id,
          customVideoUrl: generatedVideoUrl, // User can still see the base AI-generated video
        },
      });
    }
  } catch (error: any) {
    console.error('❌❌❌ COMPLETE AI VIDEO GENERATION FAILED ❌❌❌');
    console.error('Error message:', error.message);
    console.error('Error stack:', error.stack);
    console.error('Full error:', JSON.stringify(error, null, 2));
    logger.error('❌ Complete AI video generation failed:', error);

    return res.status(500).json({
      error: 'AI video generation failed',
      details: error.message,
      stack: error.stack,
      message: 'Please try again or contact support if the issue persists',
    });
  }
});

// POST /api/video-campaigns/ai/kling-video-only
// Generate video using Kling AI only (no script enhancement, no campaign creation)
router.post('/ai/kling-video-only', authenticate, async (req, res, next) => {
  try {
    const { prompt, duration = 10, aspectRatio = '16:9', mode = 'standard' } = req.body;

    const userId = (req.user as any)?.id;

    if (!userId) {
      return res.status(401).json({ error: 'User not authenticated' });
    }

    if (!prompt) {
      return res.status(400).json({
        error: 'prompt is required',
      });
    }

    logger.info('🎬 Starting Kling AI video generation (video-only mode)', {
      userId,
      promptLength: prompt.length,
      duration,
    });

    // Generate video with Kling AI
    const videoUrl = await klingAIService.generateVideo({
      prompt,
      duration: duration === 5 ? 5 : 10, // Kling AI only supports 5 or 10 seconds
      aspectRatio: aspectRatio as any,
      // Note: model parameter can be used to select kling-v1, v1-6, v2-master, etc.
    });

    logger.info('✅ Kling AI video generated successfully', { videoUrl });

    return res.json({
      success: true,
      videoUrl,
      duration,
      message: 'Video generated successfully with Kling AI',
    });
  } catch (error: any) {
    console.error('❌❌❌ KLING AI VIDEO-ONLY GENERATION FAILED ❌❌❌');
    console.error('Error message:', error.message);
    console.error('Error stack:', error.stack);
    logger.error('❌ Kling AI video-only generation failed:', error);

    return res.status(500).json({
      error: 'Kling AI video generation failed',
      details: error.message,
      message: 'Please try again or contact support if the issue persists',
    });
  }
});

