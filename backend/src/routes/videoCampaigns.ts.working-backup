router.post('/upload-logo', imageUpload.single('logo'), async (req, res, next) => {
  try {
    logger.info('Logo upload request received:', {
      hasFile: !!req.file,
      contentType: req.headers['content-type'],
      user: req.user?.email,
    });

    if (!req.file) {
      logger.error('Logo upload: No file provided');
      return res.status(400).json({
        error: 'Logo file is required',
        details: 'Please upload an image file (PNG, JPG, or SVG)'
      });
    }

    const file = req.file;
    const fileName = `logos/${req.user!.id}/${Date.now()}-${file.originalname}`;

    logger.info('Uploading logo to S3:', {
      fileName,
      size: file.size,
      bucket: S3_BUCKET,
      mimetype: file.mimetype,
    });

    // Upload to S3
    const uploadCommand = new PutObjectCommand({
      Bucket: S3_BUCKET,
      Key: fileName,
      Body: file.buffer,
      ContentType: file.mimetype,
    });

    await s3Client.send(uploadCommand);

    const logoUrl = `https://${CLOUDFRONT_DOMAIN}/${fileName}`;

    logger.info('Logo file uploaded successfully:', {
      user: req.user?.email,
      fileName,
      size: file.size,
      logoUrl,
    });

    return res.json({ logoUrl });
