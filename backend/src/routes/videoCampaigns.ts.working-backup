// POST /api/video-campaigns/synthesize-voice - Generate speech from text with cloned voice or ElevenLabs
// Note: This endpoint is called by the video generator service (internal), so it doesn't require auth
router.post('/synthesize-voice', async (req, res, next) => {
  try {
    const { text, voice_id, language = 'en' } = req.body;

    if (!text) {
      return res.status(400).json({ error: 'Text is required' });
    }

    if (!voice_id) {
      return res.status(400).json({ error: 'Voice ID is required' });
    }

    // Allow internal service calls from localhost
    const isInternalCall = req.ip === '127.0.0.1' || req.ip === '::1' || req.ip === '::ffff:127.0.0.1';

    // Normalize voice_id - if it doesn't have elevenlabs: prefix and looks like an ElevenLabs voice ID, add it
    // ElevenLabs voice IDs are typically alphanumeric strings without special characters
    let normalizedVoiceId = voice_id;
    if (!voice_id.includes(':') && !voice_id.includes('/')) {
      // Assume it's an ElevenLabs voice ID if it doesn't have a prefix
      normalizedVoiceId = `elevenlabs:${voice_id}`;
      logger.info(`Normalized voice ID from "${voice_id}" to "${normalizedVoiceId}"`);
    }

    logger.info('Synthesizing speech:', {
      textLength: text.length,
      voice_id: normalizedVoiceId,
      language,
      isInternalCall,
      ip: req.ip,
    });

    // Check if this is an ElevenLabs voice (format: elevenlabs:voice_id)
    if (normalizedVoiceId.startsWith('elevenlabs:')) {
      const elevenLabsVoiceId = normalizedVoiceId.replace('elevenlabs:', '');
      const ELEVENLABS_API_KEY = process.env.ELEVENLABS_API_KEY;

      if (!ELEVENLABS_API_KEY) {
        return res.status(500).json({
          error: 'ElevenLabs API not configured',
          details: 'Please add ELEVENLABS_API_KEY to environment variables'
        });
      }

      logger.info('Using ElevenLabs TTS:', { elevenLabsVoiceId });

      // Call ElevenLabs TTS API
      const elevenLabsResponse = await fetch(
        `https://api.elevenlabs.io/v1/text-to-speech/${elevenLabsVoiceId}`,
        {
          method: 'POST',
          headers: {
            'xi-api-key': ELEVENLABS_API_KEY,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            text,
            model_id: 'eleven_monolingual_v1',
            voice_settings: {
              stability: 0.5,
              similarity_boost: 0.75,
            },
          }),
        }
      );

      if (!elevenLabsResponse.ok) {
        const errorText = await elevenLabsResponse.text();
        logger.error('ElevenLabs TTS error:', { status: elevenLabsResponse.status, error: errorText });
        return res.status(elevenLabsResponse.status).json({
          error: 'ElevenLabs TTS failed',
          details: errorText
        });
      }

      // Get audio data as buffer
      const audioBuffer = await elevenLabsResponse.arrayBuffer();
      const audioData = Buffer.from(audioBuffer);

      // Upload to S3
      const timestamp = Date.now();
      const s3Key = `synthesized-voices/elevenlabs/${elevenLabsVoiceId}_${timestamp}.mp3`;

      const uploadCommand = new PutObjectCommand({
        Bucket: S3_BUCKET,
        Key: s3Key,
        Body: audioData,
        ContentType: 'audio/mpeg',
      });

      await s3Client.send(uploadCommand);

      const audio_url = `https://${S3_BUCKET}.s3.${process.env.AWS_REGION || 'us-east-1'}.amazonaws.com/${s3Key}`;

      logger.info('ElevenLabs TTS successful, uploaded to S3:', { audio_url });

      return res.json({
        success: true,
        audio_url,
        text_length: text.length,
        voice_id,
        method: 'elevenlabs',
        message: 'Successfully synthesized speech with ElevenLabs!',
      });
    }

    // Custom voice cloning has been removed - only ElevenLabs voices are supported
    logger.error('Invalid voice_id format. Only ElevenLabs voices are supported:', { voice_id, normalizedVoiceId });
    return res.status(400).json({
      error: 'Invalid voice selection',
      details: 'Only ElevenLabs professional voices are supported. Please select a voice from the ElevenLabs voice selector.',
      voice_id: normalizedVoiceId,
    });

  } catch (error: any) {
    logger.error('Speech synthesis error:', error);

    if (error.response) {
      return res.status(error.response.status).json({
        error: error.response.data?.error || 'Speech synthesis failed'
      });
    }

    // Return generic error for unexpected failures
    return res.status(500).json({
      error: 'Speech synthesis failed',
      details: error.message || 'An unexpected error occurred during voice synthesis'
    });
  }
});

