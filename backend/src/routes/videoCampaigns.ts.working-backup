// POST /api/video-campaigns/templates/upload - Upload video file
router.post('/templates/upload', authenticate, upload.single('video'), async (req, res, next) => {
  try {
    logger.info('📹 [UPLOAD] Template upload request received');
    logger.info('📹 [UPLOAD] User:', req.user?.email);
    logger.info('📹 [UPLOAD] File present:', !!req.file);

    if (!req.file) {
      logger.error('❌ [UPLOAD] No file in request');
      return res.status(400).json({ error: 'No video file uploaded' });
    }

    const { name, description, category } = req.body;
    const file = req.file;

    logger.info('📹 [UPLOAD] File details:', {
      originalname: file.originalname,
      mimetype: file.mimetype,
      size: file.size,
      fieldname: file.fieldname
    });

    // Generate unique filename
    const timestamp = Date.now();
    const fileExtension = file.originalname.split('.').pop();
    const s3Key = `video-templates/${req.user!.id}/${timestamp}.${fileExtension}`;

    logger.info('📹 [UPLOAD] S3 details:', {
      bucket: S3_BUCKET,
      key: s3Key,
      cloudfront: CLOUDFRONT_DOMAIN
    });

    // Upload to S3
    logger.info('📹 [UPLOAD] Starting S3 upload...');
    const uploadCommand = new PutObjectCommand({
      Bucket: S3_BUCKET,
      Key: s3Key,
      Body: file.buffer,
      ContentType: file.mimetype,
    });

    await s3Client.send(uploadCommand);
    logger.info('✅ [UPLOAD] S3 upload successful');

    const videoUrl = `https://${CLOUDFRONT_DOMAIN}/${s3Key}`;

    // Create template
    logger.info('📹 [UPLOAD] Creating database entry...');
    const template = await prisma.videoTemplate.create({
      data: {
        name: name || file.originalname,
        description,
        videoUrl,
        category: category || 'Business',
        fileSize: file.size,
        userId: req.user!.id,
        isSystem: false,
      },
    });

    logger.info('✅ [UPLOAD] Template created:', template.id);
    return res.status(201).json({ template, videoUrl });
  } catch (error) {
    logger.error('❌ [UPLOAD] Template upload error:', error);
    logger.error('❌ [UPLOAD] Error stack:', error instanceof Error ? error.stack : 'No stack');
    return next(error);
  }
});

