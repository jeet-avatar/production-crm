      user: req.user?.email,
      body: { ...req.body, narrationScript: req.body.narrationScript?.substring(0, 50) + '...' },
    });

    const {
      name,
      narrationScript,
      tone,
      videoSource,
      templateId,
      customVideoUrl,
      voiceId,
      customVoiceUrl,
      clientLogoUrl,
      userLogoUrl,
      bgmUrl,
      bgmVolume,
