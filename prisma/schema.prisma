// UI Theme Configuration
model UITheme {
  id             String   @id @default(cuid())
  name           String
  primaryColor   String
  secondaryColor String
  accentColor    String
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@map("ui_themes")
}

// Branding Configuration
model BrandingConfig {
  id             String   @id @default(cuid())
  companyName    String
  logoUrl        String?
  primaryColor   String
  secondaryColor String
  tagline        String?
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@map("branding_configs")
}

// System Credentials (Encrypted)
model SystemCredential {
  id             String    @id @default(cuid())
  name           String
  type           String    // API_KEY, OAUTH_TOKEN, SMTP, DATABASE
  service        String    // RESEND, GOOGLE, TWILIO, etc.
  encryptedValue String    @db.Text
  lastUsed       DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String

  @@index([type])
  @@index([service])
  @@index([isActive])
  @@map("system_credentials")
}

// ═════════════════════════════════════════════════════════════════
// P0 PHASE 2: AUDIT LOG & IDEMPOTENCY MODELS
// ═════════════════════════════════════════════════════════════════

// P0-02: Audit Log for Transaction Tracking
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // "COMPANY_ENRICHED", "CONTACT_CREATED", etc.
  entityType String   // "Company", "Contact", "Deal"
  entityId   String   // ID of the entity affected
  metadata   Json?    // { professionalsCreated, confidence, etc. }

  // Timestamps
  createdAt  DateTime @default(now())

  // Relationships
  user       User?    @relation("AuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// P0-07: Idempotency Key for Duplicate Prevention
model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique  // SHA-256 hash of request parameters
  userId    String
  response  Json?    // Cached response for completed requests
  status    String   // "processing", "completed", "failed"
  expiresAt DateTime // Auto-cleanup after 24 hours
  createdAt DateTime @default(now())

  // Relationships
  user      User     @relation("IdempotencyKeys", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("idempotency_keys")
}

// ============================================================================
// PARTNER PROGRAM MODELS
// ============================================================================

// Partner Program Types
model PartnerProgram {
  id              String   @id @default(cuid())
  name            String   // "Reseller", "Agency Partner", "Referral Partner"
  slug            String   @unique  // "reseller", "agency", "referral"
  commissionRate  Int      // Percentage (e.g., 20 = 20%)
  minPayment      Int      // Minimum payout threshold in cents
  description     String   @db.Text
  benefits        Json     // Array of benefit strings
  requirements    Json     // Array of requirement strings
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  applications    PartnerApplication[]

  @@index([slug])
  @@index([isActive])
  @@map("partner_programs")
}

// Partner Application Submissions
model PartnerApplication {
  id              String   @id @default(cuid())
  programId       String

  // Contact Information
  firstName       String
  lastName        String
  email           String
  phone           String?
  company         String?
  website         String?

  // Business Information
  businessType    String   // "Agency", "Consultant", "Reseller", "Freelancer", "Other"
  customersCount  String?  // "1-10", "11-50", "51-100", "100+"
  industry        String?
  yearsInBusiness String?  // "Less than 1", "1-3", "3-5", "5+"
  message         String?  @db.Text

  // Application Status
  status          String   @default("pending") // "pending", "approved", "rejected"
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?  @db.Text

  // Metadata
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  program         PartnerProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  reviewer        User?          @relation("PartnerApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
  @@map("partner_applications")
}

// Contact Sales Submissions
model ContactSubmission {
  id              String   @id @default(cuid())

  // Contact Information
  firstName       String
  lastName        String
  email           String
  phone           String?
  company         String
  companySize     String?  // "1-10", "11-50", "51-200", "201-500", "500+"

  // Inquiry Details
  inquiryType     String   // "demo", "pricing", "enterprise", "partnership", "support", "other"
  message         String   @db.Text

  // Status Tracking
  status          String   @default("new") // "new", "contacted", "qualified", "closed"
  assignedTo      String?
  followUpDate    DateTime?
  notes           String?  @db.Text

  // Metadata
  ipAddress       String?
  userAgent       String?
  source          String?  @default("website")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  assignedUser    User?    @relation("ContactSubmissionAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([inquiryType])
  @@index([createdAt])
  @@map("contact_submissions")
}
