// ===================================
// VIDEO CAMPAIGN MODELS
// ===================================

enum VideoCampaignStatus {
  DRAFT
  GENERATING
  READY
  FAILED
  PROCESSING
}

enum VideoSourceType {
  TEMPLATE
  CUSTOM_UPLOAD
  URL
}

// Video Template Library
model VideoTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  videoUrl     String // S3 URL or external URL
  thumbnailUrl String? // Auto-generated thumbnail
  duration     Int? // Duration in seconds
  width        Int? // Video width in pixels
  height       Int? // Video height in pixels
  fileSize     Int? // File size in bytes
  category     String   @default("Business") // Business, Tech, Creative, Minimal, Abstract
  tags         String[] @default([]) // Searchable tags

  // Template ownership
  isSystem Boolean @default(false) // System template vs user-uploaded
  userId   String? // null for system templates

  // User preferences & Visibility
  isActive   Boolean @default(true)  // Can disable without deletion
  isFavorite Boolean @default(false)
  isShared   Boolean @default(false) // Shared with team members
  isPublic   Boolean @default(false) // Public template library
  usageCount Int     @default(0) // Track popularity
  viewCount  Int     @default(0) // Times template was viewed

  // Free template integration (Mixkit, Pexels, etc.)
  sourceProvider String? // Mixkit, Pexels, Custom
  downloadUrl    String? @db.Text // External download URL for free templates
  license        String? @db.Text // License information
  software       String? // Premiere Pro, After Effects, Final Cut Pro
  isFree         Boolean @default(false) // Free template from external source
  isPremium      Boolean @default(false) // Premium template

  // Metadata
  metadata Json? // Additional metadata

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user      User?           @relation("VideoTemplates", fields: [userId], references: [id], onDelete: Cascade)
  campaigns VideoCampaign[]

  @@index([userId])
  @@index([category])
  @@index([isSystem])
  @@index([isActive])
  @@index([isShared])
  @@index([isPublic])
  @@index([isFavorite])
  @@index([usageCount])
  @@index([isFree])
  @@index([sourceProvider])
  @@map("video_templates")
}

// Video Campaign
model VideoCampaign {
  id          String              @id @default(cuid())
  name        String
  description String?             @db.Text
  status      VideoCampaignStatus @default(DRAFT)

  // Organization & Visibility
  category   String  @default("General") // Business, Marketing, Sales, etc.
  tags       String[] @default([])       // Searchable keywords
  isActive   Boolean @default(true)      // Can disable without deletion
  isShared   Boolean @default(false)     // Shared with team members
  isPublic   Boolean @default(false)     // Public campaign
  isFavorite Boolean @default(false)     // User favorites

  // Video Source
  videoSource    VideoSourceType @default(TEMPLATE)
  templateId     String? // If using template from library
  customVideoUrl String? // If uploaded custom video or URL

  // Video Content
  narrationScript String @db.Text
  tone            String @default("professional") // professional, friendly, enthusiastic, persuasive

  // Voice Settings
  voiceId        String? // ElevenLabs voice ID or preset voice ID
  customVoiceUrl String? // URL to custom uploaded voice sample

  // Visual Elements
  clientLogoUrl String? // Client company logo
  userLogoUrl   String? // User's company logo
  bgmUrl        String? // Background music URL
  bgmVolume     Float   @default(0.1) // BGM volume (0.0 to 1.0)

  // Text Overlays (JSON array)
  textOverlays Json? // [{text, startTime, duration, fontSize, color, position}]

  // Generated Video
  videoUrl     String? // Final generated video URL (S3)
  thumbnailUrl String? // Video thumbnail
  duration     Int? // Final video duration in seconds

  // Generation metadata
  generatedAt         DateTime?
  generationError     String?   @db.Text
  generationTime      Int? // Time taken to generate in seconds
  processingStartedAt DateTime? // When video generation started
  progressPercent     Int?      @default(0) // Progress percentage (0-100)
  estimatedCompletion DateTime? // Estimated completion time

  // Analytics & Usage Tracking
  usageCount Int @default(0) // Times campaign was used/sent
  views      Int @default(0)
  clicks     Int @default(0)
  shares     Int @default(0)
  downloads  Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign Keys
  userId          String
  emailTemplateId String? // Link to email template to update with video
  campaignId      String? @map("campaign_id") // Link to email campaign (for one-click automation)
  contactId       String? @map("contact_id") // Link to contact recipient (for personalization)

  // Relationships
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      VideoTemplate?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  emailTemplate EmailTemplate?         @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  campaign      Campaign?              @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact       Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companies     VideoCampaignCompany[]
  jobs          VideoGenerationJob[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([isActive])
  @@index([isShared])
  @@index([isPublic])
  @@index([isFavorite])
  @@index([templateId])
  @@index([emailTemplateId])
  @@index([campaignId])
  @@index([contactId])
  @@index([createdAt])
  @@index([videoSource])
  @@map("video_campaigns")
}

// Video Campaign Company Association
model VideoCampaignCompany {
  campaignId String
  companyId  String

  // Tracking
  sentAt    DateTime?
  viewed    Boolean   @default(false)
  clicked   Boolean   @default(false)
  viewedAt  DateTime?
  clickedAt DateTime?
  viewCount Int       @default(0)

  // Metadata
  addedAt DateTime @default(now())

  // Relationships
  campaign VideoCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  company  Company       @relation("VideoCampaigns", fields: [companyId], references: [id], onDelete: Cascade)

  @@id([campaignId, companyId])
  @@index([campaignId])
  @@index([companyId])
  @@map("video_campaign_companies")
}

// Video Generation Job Queue
model VideoGenerationJob {
  id         String @id @default(cuid())
  campaignId String

  // Job Status
  status   String @default("pending") // pending, processing, completed, failed
  progress Int    @default(0) // 0-100

  // Job Details
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?   @db.Text

  // Queue metadata
  queueId     String? // Bull queue job ID
  attempts    Int     @default(0)
  maxAttempts Int     @default(3)

  // Processing metadata
  currentStep String? // Which step is currently processing
  logs        Json? // Processing logs array

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  campaign VideoCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("video_generation_jobs")
}

// ===================================
// EMAIL UNSUBSCRIBE MODEL
// ===================================

model EmailUnsubscribe {
  id    String @id @default(cuid())
  email String @unique

  // Unsubscribe Details
  reason   String? // Why they unsubscribed (dropdown selection)
  feedback String? // Additional feedback from user

  // Tracking
  campaignId String? // Which campaign triggered the unsubscribe
  contactId  String? // Contact who unsubscribed

  // Metadata
  unsubscribedAt DateTime @default(now())
  ipAddress      String?
  userAgent      String?

  // Confirmation (two-step unsubscribe)
  confirmed   Boolean  @default(false)
  token       String   @unique // Secure token for confirmation
  tokenExpiry DateTime // Token expires after 24 hours

  // Timestamps
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([campaignId])
  @@index([contactId])
  @@index([confirmed])
  @@map("email_unsubscribes")
}

// Media Access Tracking
model MediaAccess {
  id        String   @id @default(cuid())
  mediaKey  String // e.g., "video/netsuite-demo", "img/netsuite-preview"
  source    String   @default("unknown") // e.g., "email", "landing", "direct"
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Client info
  ipAddress String @default("unknown")
  userAgent String @default("unknown")

  // Timestamps
  accessedAt DateTime @default(now())

  @@index([mediaKey])
  @@index([source])
  @@index([contactId])
  @@index([accessedAt])
  @@map("media_accesses")
}

// Website Visitor Tracking - Track all visits to brandmonkz.com
model WebsiteVisit {
  id String @id @default(cuid())

  // URL Information
  fullUrl     String // Complete URL with protocol, domain, path, query
  protocol    String // http or https
  domain      String // brandmonkz.com or www.brandmonkz.com
  path        String  @default("/") // e.g., "/dashboard", "/login"
  queryParams String? // JSON string of query parameters
  referrer    String? // Where the visitor came from

  // User Information
  userId    String? // If logged in
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String? // Browser session identifier

  // Device & Browser Information
  ipAddress      String
  userAgent      String  @db.Text
  browser        String? // Chrome, Firefox, Safari, etc.
  browserVersion String?
  os             String? // Windows, MacOS, Linux, iOS, Android
  osVersion      String?
  device         String? // Desktop, Mobile, Tablet
  deviceVendor   String? // Apple, Samsung, etc.

  // Geographic Information
  country String?

  // Engagement Metrics
  pageLoadTime Int? // Milliseconds
  timeOnPage   Int? // Seconds (updated if tracked)
  scrollDepth  Int? // Percentage of page scrolled

  // Visit Metadata
  isAuthenticated Boolean @default(false)
  isNewVisitor    Boolean @default(true)
  visitCount      Int     @default(1) // How many times this session visited

  // Timestamps
  visitedAt DateTime  @default(now())
  leftAt    DateTime? // When user left the page (if tracked)

  @@index([domain])
  @@index([path])
  @@index([userId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([visitedAt])
  @@index([isAuthenticated])
  @@index([country])
  @@map("website_visits")
}

// User Login Session Tracking
model UserSession {
  id String @id @default(cuid())

  // User Information
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session Details
  sessionToken String  @unique // JWT token or session identifier
  refreshToken String? // For refresh token rotation

  // Login Information
  loginAt   DateTime  @default(now())
  logoutAt  DateTime? // When user explicitly logged out
  expiresAt DateTime // Session expiration time

  // Connection Details
  ipAddress      String
  userAgent      String  @db.Text
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  device         String? // Desktop, Mobile, Tablet

  // Location Information
  country String?
  region  String?
  city    String?

  // Session Metrics
  lastActivityAt DateTime @default(now()) // Last API call or activity
  totalDuration  Int      @default(0) // Total time in seconds
  pageViews      Int      @default(0) // Number of pages viewed
  actionsCount   Int      @default(0) // Number of actions performed

  // Session Status
  isActive    Boolean @default(true)
  endedReason String? // "logout", "timeout", "expired", "forced"

  // Relationships
  activities UserActivity[]

  @@index([userId])
  @@index([sessionToken])
  @@index([loginAt])
  @@index([isActive])
  @@index([lastActivityAt])
  @@map("user_sessions")
}

// User Activity Tracking - What users do during their sessions
model UserActivity {
  id String @id @default(cuid())

  // User and Session
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Activity Details
  action     String // "view", "create", "update", "delete", "export", "import", "send_email", etc.
  resource   String // "contact", "campaign", "deal", "email", "dashboard", etc.
  resourceId String? // ID of the specific resource if applicable

  // Activity Context
  method     String @default("GET") // HTTP method
  endpoint   String // API endpoint called
  statusCode Int? // Response status code

  // Performance Metrics
  duration Int? // Time taken in milliseconds

  // Additional Data
  metadata  Json? // Additional context (filters used, search terms, etc.)
  ipAddress String

  // Timestamps
  performedAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([action])
  @@index([resource])
  @@index([performedAt])
  @@map("user_activities")
}

// Security - Blocked IP Addresses
model BlockedIP {
  id        String    @id @default(cuid())
  ipAddress String    @unique
  reason    String?   @db.Text
  blockedBy String? // User ID or email who blocked this IP
  blockedAt DateTime  @default(now())
  expiresAt DateTime? // Optional: Auto-unblock after certain time
  isActive  Boolean   @default(true)

  // Threat Information
  threatLevel String? // critical, high, medium, low
  attackType  String? // Type of attack detected
  attempts    Int     @default(0) // Number of attack attempts

  // Geographic Information
  country String?
  region  String?
  city    String?

  // Additional Context
  metadata Json? // Store additional context (user agent, attack patterns, etc.)

  @@index([ipAddress])
  @@index([isActive])
  @@index([blockedAt])
  @@map("blocked_ips")
}

// Email Footer Configuration - Centralized footer management
model EmailFooterConfig {
  id String @id @default(cuid())

  // Owner
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Footer Identity
  companyName String  @default("BrandMonkz")
  tagline     String? // Optional company tagline

  // Mission Statement
  missionStatement String? @db.Text

  // Contact Information
  supportEmail String?
  supportPhone String?
  address      String? // Physical address (required by CAN-SPAM)
  website      String? // Company website

  // Social Media Links
  linkedinUrl  String?
  twitterUrl   String?
  facebookUrl  String?
  instagramUrl String?
  youtubeUrl   String?

  // Legal & Compliance Links
  privacyPolicyUrl  String?
  termsOfServiceUrl String?
  gdprUrl           String?
  cookiePolicyUrl   String?
  dpaUrl            String? // Data Processing Agreement

  // Quick Links (stored as JSON for flexibility)
  productLinks  Json? // { "Features": "https://...", "Pricing": "..." }
  resourceLinks Json? // { "Blog": "https://...", "Help Center": "..." }
  companyLinks  Json? // { "About": "https://...", "Careers": "..." }

  // Customization Options
  showSocialMedia Boolean @default(true)
  showMission     Boolean @default(true)
  showQuickLinks  Boolean @default(true)
  showContactInfo Boolean @default(true)
  showLegalLinks  Boolean @default(true)
  showGdprNotice  Boolean @default(true)
  showWebVersion  Boolean @default(true)

  // Brand Colors (for footer styling)
  primaryColor   String @default("#FB923C") // Orange
  secondaryColor String @default("#F43F5E") // Rose

  // Footer Text Customization
  gdprNoticeText       String? @db.Text // Custom GDPR notice
  copyrightText        String? // Custom copyright text
  additionalFooterText String? @db.Text // Any additional text

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false) // Is this the default footer for the user?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([isDefault])
  @@map("email_footer_configs")
}

// ============================================
// API Key Management Models
// ============================================

enum ApiKeyType {
  LIVE // Production keys (bmz_live_*)
  TEST // Test/sandbox keys (bmz_test_*)
  SECRET // Secret keys (bmz_secret_*)
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
  SUSPENDED
}

enum ApiProduct {
  LEAD_DISCOVERY
  AI_CONTENT
  VIDEO_CAMPAIGN
  EMAIL_INTELLIGENCE
  ENRICHMENT
  CRM_OPERATIONS
  INTEGRATION
  ALL_PRODUCTS
}

model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Key Details
  name      String // User-friendly name: "Production Key", "Development Key"
  keyPrefix String       @unique // First 8 chars: bmz_live_abc1
  keyHash   String       @unique // SHA-256 hash of full key
  keyType   ApiKeyType   @default(LIVE)
  status    ApiKeyStatus @default(ACTIVE)

  // Permissions & Scopes
  scopes   Json // Array of scopes: ["leads:read", "leads:write", "campaigns:read"]
  products Json // Array of ApiProduct enums

  // Rate Limiting
  rateLimit  Int @default(20) // Requests per second
  burstLimit Int @default(50) // Burst allowance
  dailyLimit Int @default(10000) // Daily request limit

  // Security
  ipWhitelist Json? // Array of allowed IPs (null = all IPs allowed)
  expiresAt   DateTime? // Optional expiration date
  lastUsedAt  DateTime? // Last time key was used
  lastUsedIp  String? // Last IP that used this key

  // Usage Tracking
  totalRequests Int           @default(0)
  usage         ApiKeyUsage[]

  // Metadata
  description String? @db.Text
  environment String? // "production", "staging", "development"

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?
  revokedBy String? // User ID who revoked the key

  @@index([userId])
  @@index([keyPrefix])
  @@index([status])
  @@index([keyType])
  @@index([createdAt])
  @@map("api_keys")
}

model ApiKeyUsage {
  id       String @id @default(cuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  // Request Details
  endpoint     String // "/api/leads/discover"
  method       String // "POST"
  statusCode   Int // 200, 400, 429, etc.
  responseTime Int // Milliseconds

  // Product & Credits
  product     ApiProduct
  creditsUsed Int        @default(0) // API-specific credits consumed

  // Request Metadata
  ipAddress String?
  userAgent String? @db.Text
  requestId String? @unique

  // Error Information
  errorCode    String?
  errorMessage String? @db.Text

  // Timestamp
  timestamp DateTime @default(now())
  date      DateTime @default(now()) @db.Date // For daily aggregation

  @@index([apiKeyId])
  @@index([timestamp])
  @@index([date])
  @@index([product])
  @@index([statusCode])
  @@map("api_key_usage")
}

model ApiSubscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan Details
  planName     String // "API Starter Bundle", "API Professional Bundle"
  planTier     String // "free", "starter", "professional", "business", "enterprise"
  monthlyPrice Int // In cents: 49900 = $499

  // Product Limits
  leadCredits       Int @default(0) // Monthly lead discovery credits
  aiRequests        Int @default(0) // Monthly AI generation requests
  videoCredits      Int @default(0) // Monthly video generations
  emailCredits      Int @default(0) // Monthly email tracking
  enrichmentCredits Int @default(0) // Monthly enrichment credits
  crmApiCalls       Int @default(0) // Monthly CRM API calls
  integrationCalls  Int @default(0) // Monthly integration API calls

  // Usage This Month
  usedLeadCredits       Int @default(0)
  usedAiRequests        Int @default(0)
  usedVideoCredits      Int @default(0)
  usedEmailCredits      Int @default(0)
  usedEnrichmentCredits Int @default(0)
  usedCrmApiCalls       Int @default(0)
  usedIntegrationCalls  Int @default(0)

  // Billing
  billingCycle       String // "monthly", "annual"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)

  // Status
  status      String    @default("active") // "active", "cancelled", "past_due", "trialing"
  trialEndsAt DateTime?

  // Stripe Integration
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cancelledAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("api_subscriptions")
}

model ApiWebhook {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Webhook Details
  name   String // "Lead Discovery Webhook"
  url    String // "https://yourapp.com/webhooks/brandmonkz"
  secret String // HMAC secret for signature verification

  // Events to Subscribe
  events Json // ["lead.discovered", "video.generated", "email.sent"]

  // Status
  isActive Boolean @default(true)

  // Retry Configuration
  maxRetries Int @default(3)
  retryDelay Int @default(60) // Seconds between retries

  // Statistics
  totalDeliveries      Int       @default(0)
  successfulDeliveries Int       @default(0)
  failedDeliveries     Int       @default(0)
  lastDeliveryAt       DateTime?
  lastDeliveryStatus   String? // "success", "failed"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries ApiWebhookDelivery[]

  @@index([userId])
  @@index([isActive])
  @@map("api_webhooks")
}

model ApiWebhookDelivery {
  id        String     @id @default(cuid())
  webhookId String
  webhook   ApiWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  // Event Details
  event   String // "lead.discovered"
  payload Json // Full event payload

  // Delivery Details
  statusCode   Int? // HTTP status code
  responseBody String? @db.Text
  responseTime Int? // Milliseconds

  // Retry Information
  attempt     Int @default(1)
  maxAttempts Int @default(3)

  // Status
  status       String // "pending", "delivered", "failed"
  errorMessage String? @db.Text

  // Timestamps
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  nextRetryAt DateTime?

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@index([nextRetryAt])
  @@map("api_webhook_deliveries")
}

